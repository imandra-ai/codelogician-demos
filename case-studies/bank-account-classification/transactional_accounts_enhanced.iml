(* Bank Account Classification Analysis — Enhanced Version
   Adds balance threshold check. Code grew 21% but behavioral regions grew 190%
   (19 to 55 regions), showing how a simple change dramatically increases complexity. *)

type deal_product_type_code =
  | Transaction
  | CMA_Direct
  | CMA_Platform
  | BB_Cheque_Account
  | BB_Regulated_Trust_Account
  | Other

type transaction_type =
  | Transfer
  | Direct_Debit
  | BPAY_Payment
  | Loan_Drawdown
  | Withdrawal
  | Deposit
  | RTGS_Payment
  | Cheque
  | Payment
  | Dividend
  | Debit_Card
  | Interest_Credit
  | Fee_Debit
  | Reversal
  | Adjustment
  | Tax_Payment
  | Government_Benefit
  | Salary_Credit
  | Refund
  | Standing_Order
  | Other_Transaction

type debit_credit_indicator = DR | CR

type yn_flag = Y | N

type date = { year : int; month : int; day : int }

type account = {
  deal_business_date : date;
  deal_identifier : int;
  counterparty_identifier : int;
  deal_product_type_code : deal_product_type_code;
  avg_30_day_balance : real;
  current_spot_interest_rate : real;
}

type account_transaction = {
  txn_deal_identifier : int;
  transaction_identifier : int;
  transaction_type : transaction_type;
  transaction_amount : int;
  transaction_debit_credit_indicator : debit_credit_indicator;
  transaction_date : date;
  transaction_reversal_flag : yn_flag;
}

type transaction_lookback_period = {
  start_date : date;
  end_date : date;
}

type analysis_result = {
  eligible_transaction_product_flag : yn_flag;
  depositor_initiated_inflows : int;
  depositor_initiated_outflows : int;
  passed_active_use_test_flag : yn_flag;
  predicted_balance_outside_flag : yn_flag;
  is_transactional_flag : yn_flag;
}

(* $25M in cents *)
let balance_threshold : real = 2500000000.0

let is_eligible_product (product_type : deal_product_type_code) : yn_flag =
  match product_type with
  | Transaction -> Y
  | CMA_Direct -> Y
  | CMA_Platform -> Y
  | BB_Cheque_Account -> Y
  | BB_Regulated_Trust_Account -> Y
  | Other -> N

let is_depositor_initiated (txn_type : transaction_type) : bool =
  match txn_type with
  | Transfer -> true
  | Direct_Debit -> true
  | BPAY_Payment -> true
  | Loan_Drawdown -> true
  | Withdrawal -> true
  | Deposit -> true
  | RTGS_Payment -> true
  | Cheque -> true
  | Payment -> true
  | Dividend -> true
  | Debit_Card -> true
  | _ -> false

let is_inflow (ind : debit_credit_indicator) : bool = ind = CR

let is_outflow (ind : debit_credit_indicator) : bool = ind = DR

let date_leq (d1 : date) (d2 : date) : bool =
  if d1.year < d2.year then true
  else if d1.year > d2.year then false
  else if d1.month < d2.month then true
  else if d1.month > d2.month then false
  else d1.day <= d2.day

let is_in_lookback_period (txn_date : date) (lookback : transaction_lookback_period) : bool =
  date_leq lookback.start_date txn_date && date_leq txn_date lookback.end_date

let rec count_flows
    (transactions : account_transaction list)
    (deal_id : int)
    (lookback : transaction_lookback_period)
    : int * int =
  match transactions with
  | [] -> (0, 0)
  | t :: rest ->
    let (inflows, outflows) = count_flows rest deal_id lookback in
    if t.txn_deal_identifier = deal_id
       && is_in_lookback_period t.transaction_date lookback
       && is_depositor_initiated t.transaction_type then
      if is_inflow t.transaction_debit_credit_indicator then
        (inflows + 1, outflows)
      else if is_outflow t.transaction_debit_credit_indicator then
        (inflows, outflows + 1)
      else
        (inflows, outflows)
    else
      (inflows, outflows)

(* New: balance threshold check *)
let check_predicted_balance_threshold
    (avg_balance : real)
    (interest_rate : real)
    : yn_flag =
  let predicted_balance = avg_balance *. (1.0 +. interest_rate) in
  if predicted_balance >. balance_threshold then Y else N

let analyze_transactional_account_enhanced
    (acct : account)
    (transactions : account_transaction list)
    (lookback : transaction_lookback_period)
    : analysis_result =
  let eligible_flag = is_eligible_product acct.deal_product_type_code in
  let (inflow_count, outflow_count) = count_flows transactions acct.deal_identifier lookback in
  let passed_active_use =
    if inflow_count >= 3 && outflow_count >= 3 then Y else N
  in
  let predicted_balance_outside =
    check_predicted_balance_threshold acct.avg_30_day_balance acct.current_spot_interest_rate
  in
  let is_transactional =
    match eligible_flag, passed_active_use, predicted_balance_outside with
    | Y, Y, N -> Y
    | _ -> N
  in
  {
    eligible_transaction_product_flag = eligible_flag;
    depositor_initiated_inflows = inflow_count;
    depositor_initiated_outflows = outflow_count;
    passed_active_use_test_flag = passed_active_use;
    predicted_balance_outside_flag = predicted_balance_outside;
    is_transactional_flag = is_transactional;
  }
